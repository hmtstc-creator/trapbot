# ╔══════════════════════════════════════════════════════════╗
# ║  TRAPBOT BACKEND AYARLARI — backend/.env dosyası        ║
# ║  Bu dosyayı backend/ klasörünün İÇİNE koy               ║
# ║  Adı tam olarak: .env (nokta ile başlar)                 ║
# ╚══════════════════════════════════════════════════════════╝
#
# Her satırda = işaretinden sonraki kısmı kendi bilginle değiştir
# Tırnakları silme, boşluk bırakma

# ── Binance ──────────────────────────────────────────────────────
# Testnet key almak için: https://testnet.binance.vision
# GitHub ile giriş → Generate HMAC_SHA256 Key → Kopyala
BINANCE_API_KEY=BURAYA_BINANCE_API_KEY_YAZ
BINANCE_API_SECRET=BURAYA_BINANCE_API_SECRET_YAZ

# true = testnet (güvenli, sahte para)
# false = gerçek Binance (dikkatli ol!)
BINANCE_TESTNET=true

# ── Supabase ─────────────────────────────────────────────────────
# https://supabase.com → Projen → Settings → API
# "Project URL" kısmı (https://xxxx.supabase.co şeklinde)
SUPABASE_URL=BURAYA_SUPABASE_URL_YAZ
# "anon public" key kısmı (eyJ ile başlayan uzun kod)
SUPABASE_KEY=BURAYA_SUPABASE_ANON_KEY_YAZ

# ── Render.com otomatik doldurur, dokunma ────────────────────────
PORT=8000
